<Page x:Class="LCTWorks.Workshop.Views.Items.SampleCodePresenterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:clocal="using:LCTWorks.Workshop.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:LCTWorks.Workshop.Views.Items"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical">
                <clocal:SampleCodePresenter x:Name="Sample"
                                            Margin="16"
                                            CSharpCodeFilePath="ms-appx:///Assets/CodeSnippets/SampleCodePresenter_Cs.txt"
                                            Description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam pharetra, tellus sit amet congue vulputate, nisi erat iaculis nibh, vitae feugiat sapien ante eget mauris. Aenean sollicitudin imperdiet arcu, v"
                                            ExpanderHeader="Code here"
                                            Header="Some header"
                                            MarkdownFilePath="ms-appx:///Assets/CodeSnippets/SampleCodePresenter_Md.txt"
                                            MarkdownTabHeader="Documentation"
                                            MinOptionsPaneWidth="240"
                                            XamlCodeFilePath="ms-appx:///Assets/CodeSnippets/SampleCodePresenter_Xaml.txt">
                    <clocal:SampleCodePresenter.Content>
                        <Border MinWidth="420"
                                MinHeight="240"
                                Background="{ThemeResource AppBarBackgroundThemeBrush}"
                                CornerRadius="16">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="Sample control goes here" />
                        </Border>
                    </clocal:SampleCodePresenter.Content>
                    <clocal:SampleCodePresenter.OptionsPaneContent>
                        <Border Background="{ThemeResource AppBarBackgroundThemeBrush}"
                                CornerRadius="16">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="Control options go here" />
                        </Border>
                    </clocal:SampleCodePresenter.OptionsPaneContent>
                </clocal:SampleCodePresenter>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>