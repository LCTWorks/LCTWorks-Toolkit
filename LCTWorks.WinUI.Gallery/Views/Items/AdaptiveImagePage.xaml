<Page x:Class="LCTWorks.Workshop.Items.AdaptiveImagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:c="using:LCTWorks.WinUI.Controls"
      xmlns:clocal="using:LCTWorks.Workshop.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:LCTWorks.Workshop.Items"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical">
                <clocal:SampleCodePresenter x:Name="Sample"
                                            Margin="16"
                                            HorizontalContentAlignment="Stretch"
                                            Description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam pharetra, tellus sit amet congue vulputate, nisi erat iaculis nibh, vitae feugiat sapien ante eget mauris. Aenean sollicitudin imperdiet arcu, v"
                                            ExpanderHeader="Code here"
                                            Header="Some header"
                                            IsLoadingBarVisible="True"
                                            MarkdownFilePath="ms-appx:///Assets/CodeSnippets/Sample1_Plain.txt"
                                            MarkdownTabHeader="Docs"
                                            MinOptionsPaneWidth="200"
                                            XamlCodeFilePath="ms-appx:///Assets/CodeSnippets/Sample1_Xaml.txt">
                    <clocal:SampleCodePresenter.Content>
                        <c:AdaptiveImage x:Name="img"
                                         Width="64"
                                         Height="64"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         PlaceholderSource="/Assets/Icons/AdaptiveImage.svg" />
                    </clocal:SampleCodePresenter.Content>
                    <clocal:SampleCodePresenter.OptionsPaneContent>
                        <StackPanel MinWidth="240"
                                    Orientation="Vertical"
                                    Spacing="8">
                            <AutoSuggestBox Header="Source"
                                            QueryIcon="BrowsePhotos" />
                            <TextBlock Foreground="{ThemeResource SystemErrorTextColor}"
                                       Text="Error here" />
                            <ToggleSwitch IsEnabled="True"
                                          OffContent="Placeholder disabled"
                                          OnContent="Placeholder enabled" />
                        </StackPanel>
                    </clocal:SampleCodePresenter.OptionsPaneContent>
                </clocal:SampleCodePresenter>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>