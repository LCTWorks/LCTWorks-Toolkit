<c:ObservablePage x:Class="LCTWorks.Workshop.Items.AdaptiveImagePage"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:c="using:LCTWorks.WinUI.Controls"
                  xmlns:clocal="using:LCTWorks.Workshop.Controls"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="using:LCTWorks.Workshop.Items"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <StackPanel Orientation="Vertical">
                <clocal:SampleCodePresenter x:Name="Sample1Control"
                                            Margin="16"
                                            HorizontalContentAlignment="Stretch"
                                            Description="Basic properties and image behavior"
                                            ExpanderHeader="Code here"
                                            Header="AdaptiveImage"
                                            MinOptionsPaneWidth="200"
                                            XamlCodeFilePath="ms-appx:///Assets/CodeSnippets/AdaptiveImage_1_Xaml.txt">
                    <clocal:SampleCodePresenter.Content>
                        <c:AdaptiveImage x:Name="S1Img"
                                         Width="640"
                                         Height="480"
                                         Margin="16"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         ImageFailed="S1ImgImageFailed"
                                         ImageLoaded="S1ImgImageLoaded"
                                         ImageLoading="S1ImgImageLoading"
                                         Source="{x:Bind S1ImageSource, Mode=OneWay}" />
                    </clocal:SampleCodePresenter.Content>
                    <clocal:SampleCodePresenter.OptionsPaneContent>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <StackPanel Width="320"
                                        Orientation="Vertical"
                                        Spacing="8">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Header="Image source"
                                             IsReadOnly="True"
                                             Text="{x:Bind S1ImageSourceString, Mode=OneWay}" />
                                    <Button Grid.Column="1"
                                            VerticalAlignment="Bottom"
                                            Content="Browse"
                                            Tapped="S1BrowseTapped" />
                                </Grid>

                                <TextBlock x:Name="S1ErrorTextBlock"
                                           Foreground="{ThemeResource SystemErrorTextColor}"
                                           Visibility="Collapsed" />
                                <NumberBox Header="Animation duration (in Ms)"
                                           IsEnabled="False"
                                           Value="1000" />
                                <ToggleSwitch IsOn="{x:Bind ShowPlaceholder, Mode=TwoWay}"
                                              OffContent="Placeholder disabled"
                                              OnContent="Placeholder enabled" />
                                <Button HorizontalAlignment="Stretch"
                                        Content="Load image from web source"
                                        Tapped="S1LoadWebButtonTapped" />
                                <Button HorizontalAlignment="Stretch"
                                        Content="Load image from app resources"
                                        Tapped="S1LoadAppButtonTapped" />
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Margin="16"
                                       VerticalAlignment="Bottom">
                                <Run Text="State: " />
                                <Run x:Name="S1NotificationRun"
                                     Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                            </TextBlock>
                        </Grid>
                    </clocal:SampleCodePresenter.OptionsPaneContent>
                </clocal:SampleCodePresenter>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</c:ObservablePage>