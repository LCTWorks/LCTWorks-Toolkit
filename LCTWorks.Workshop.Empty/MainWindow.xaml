<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="LCTWorks.Workshop.Empty.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lctworks="using:LCTWorks.WinUI.Experimental.Controls"
        xmlns:local="using:LCTWorks.Workshop.Empty"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="LCTWorks.Workshop.Empty"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    Spacing="8">
            <lctworks:ThemedButton Content="Themed button"
                                   Style="{StaticResource DangerThemedButtonStyle}"
                                   Tapped="ThemedButton_Tapped" />
            <TextBlock FontFamily="{StaticResource FluentIconsFontFamily}"
                       Text="Some text here" />
        </StackPanel>
    </Grid>
</Window>